# Git Warden local config. Copy to `.env` (gitignored) and fill in.
# Real environment variables override these. Used by both local runs and CI.

# --- Required ----------------------------------------------------------------
# GitHub PAT: read-only public access is enough for scanning; the token lifts the
# rate limit to 5,000/hr and is required for GraphQL. Contents:write is only
# needed if a local run pushes the README registry back.
GW_GITHUB_TOKEN=

# OpenSourceMalware (OSM) API key ("osm_..."), Bearer auth.
GW_OSM_API_KEY=

# --- Optional ----------------------------------------------------------------
# OSM base URL (defaults to the public endpoint if unset).
# GW_OSM_BASE_URL=https://api.opensourcemalware.com/functions/v1/

# The contributor credited on threat reports you submit to OSM. Set this to YOUR
# OSM username/org so your reports are attributed to you. Blank = omit the field.
# GW_OSM_CONTRIBUTOR=
# Optional contact email attached to your OSM submissions (for follow-up).
# GW_OSM_CONTACT_EMAIL=

# Discord webhook for the gold feed (Wall of Shame). Omit to skip Discord.
# GW_DISCORD_WEBHOOK=

# SQLite path (defaults to ./data/git_warden.sqlite). The DB is gitignored and is
# created on first run; it never lives in git. CI persists it via the Actions
# cache between runs, so a local run just builds its own.
# GIT_WARDEN_DB=data/git_warden.sqlite

# Tier-2 clone scratch dir (defaults to system temp). Point at a roomy disk if
# your system drive is tight, e.g. GW_WORK_DIR=F:\gw-work
# GW_WORK_DIR=
