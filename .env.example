# Git Warden credentials and config.
# Copy to `.env` for local runs (`.env` is gitignored). In CI, set these as
# encrypted GitHub Actions secrets with the SAME names.

# --- Credentials -------------------------------------------------------------

# GitHub PAT, READ-ONLY public access. Fine-grained: "Public repositories
# (read-only)" => Contents:Read + Metadata:Read. Or a classic PAT with NO
# scopes. Required for GraphQL and the 5,000 req/hr rate limit.
GW_GITHUB_TOKEN=

# OpenSourceMalware API token (prefixed osm_). Sent as Authorization: Bearer.
GW_OSM_API_KEY=
# Optional base-URL override (default is the public OSM base).
# GW_OSM_BASE_URL=https://api.opensourcemalware.com/functions/v1/

# Discord webhook URL for gold findings + health alerts. Treat as a secret.
GW_DISCORD_WEBHOOK=

# (No NVD key needed -- free OSINT feeds + OSM cover the intel sources for now.)

# --- Optional overrides (sensible defaults exist in config.py) ---------------

# GIT_WARDEN_DB=./data/git_warden.sqlite
# GIT_WARDEN_MIN_SOURCES=2
# GW_SEED_ACTORS=./config/seed_actors.json
# GW_GOOGLE_NEWS_RSS_URL=https://news.google.com/rss/search
# GW_CISA_FEED_URL=https://www.cisa.gov/cybersecurity-advisories/all.xml
# GW_HTTP_TIMEOUT=20
# GW_USER_AGENT=git-warden/0.1 (+defensive-threat-intelligence)
